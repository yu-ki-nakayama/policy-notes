{"config":{"lang":["ja"],"separator":"[\\s\\-\u3000\u3001\u3002\uff0c\uff0e]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u4e2d\u5c71\u96c4\u7a00 Policy Notes","text":""},{"location":"#_1","title":"\u306f\u3058\u3081\u306b","text":"<p>\u4e2d\u5c71\u96c4\u7a00\uff08\u6771\u4eac\u5927\u5b66\u516c\u5171\u653f\u7b56\u5927\u5b66\u9662 \u6240\u5c5e\uff09\u3002 \u653f\u6cbb\u30fb\u7d4c\u6e08\u306e\u8ad6\u70b9\u3092\u300c\u5236\u5ea6\u2192\u4e89\u70b9\u2192\u9078\u629e\u80a2\u300d\u306e\u9806\u3067\u6574\u7406\u3057\u3001\u6708\u6b21\u3067\u516c\u958b\u3059\u308b\u3002</p>"},{"location":"#_2","title":"\u8aad\u307f\u65b9\u30fb\u904b\u7528\u65b9\u91dd","text":"<ul> <li>\u5f62\u5f0f\uff1a\u6708\u6b21\u30c6\u30fc\u30de\uff08\u6587\u732e\u30fb\u8b1b\u7fa9\u30b5\u30de\u30ea\u30fc\uff0f\u4e00\u6b21\u60c5\u5831\uff09</li> <li>\u65b9\u91dd\uff1a\u4e8b\u5b9f\uff08Facts\uff09\u3068\u610f\u898b\uff08View\uff09\u3092\u533a\u5225\u3057\u3001\u4e00\u6b21\u60c5\u5831\u3092\u512a\u5148\u3059\u308b\u3002</li> <li>\u514d\u8cac\uff1a\u500b\u4eba\u306e\u5b66\u7fd2\u30e1\u30e2\u3067\u3042\u308a\u3001\u8aa4\u308a\u304c\u3042\u308a\u5f97\u308b\u3002\u5fc5\u8981\u306b\u5fdc\u3058\u3066\u4fee\u6b63\u3059\u308b\u3002</li> </ul>"},{"location":"#_3","title":"\u30b3\u30f3\u30c6\u30f3\u30c4","text":"<ul> <li>\u6708\u6b21\u30c6\u30fc\u30de\uff08\u5e74\u6708\u5225\u4e00\u89a7\uff09</li> <li>\u6d3b\u52d5\u30ed\u30b0\uff08\u5bfe\u5916\u6d3b\u52d5\u30fb\u904b\u55b6\u8a18\u9332\uff09</li> <li>\u6708\u6b21\u30c6\u30f3\u30d7\u30ec\uff08\u30b3\u30d4\u30da\u7528\uff09</li> <li>\u81ea\u5df1\u7d39\u4ecb\u30fb\u9023\u7d61\u5148</li> </ul>"},{"location":"#_4","title":"\u6700\u8fd1\u306e\u66f4\u65b0","text":"<ul> <li>2026-04\uff08\u4e88\u5b9a\uff09\uff1a\u793e\u4f1a\u4fdd\u969c</li> </ul>"},{"location":"about/","title":"\u81ea\u5df1\u7d39\u4ecb\u30fb\u9023\u7d61\u5148","text":"<p>\u4e2d\u5c71\u96c4\u7a00\u3002\u653f\u6cbb\